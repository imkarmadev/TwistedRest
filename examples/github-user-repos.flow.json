{
  "twistedrest": 1,
  "name": "GitHub User Repos",
  "nodes": [
    {
      "id": "start",
      "kind": "start",
      "position": { "x": 60, "y": 200 },
      "config": { "environmentId": null }
    },
    {
      "id": "env-user",
      "kind": "envVar",
      "position": { "x": 60, "y": 380 },
      "config": { "varKey": "username" }
    },
    {
      "id": "convert-user",
      "kind": "convert",
      "position": { "x": 240, "y": 380 },
      "config": { "targetType": "string" }
    },
    {
      "id": "http-user",
      "kind": "httpRequest",
      "position": { "x": 320, "y": 160 },
      "config": {
        "method": "GET",
        "url": "https://api.github.com/users/#{username}",
        "headers": [{ "key": "Accept", "value": "application/vnd.github.v3+json", "enabled": true }],
        "body": "",
        "responseSchema": "z.object({\n  login: z.string(),\n  name: z.string().nullable(),\n  public_repos: z.number(),\n  followers: z.number()\n})"
      }
    },
    {
      "id": "log-user",
      "kind": "log",
      "position": { "x": 640, "y": 100 },
      "config": { "label": "User info" }
    },
    {
      "id": "make-user",
      "kind": "makeObject",
      "position": { "x": 640, "y": 240 },
      "config": {
        "fields": [
          { "key": "name", "type": "string" },
          { "key": "repos", "type": "number" },
          { "key": "followers", "type": "number" }
        ]
      }
    },
    {
      "id": "http-repos",
      "kind": "httpRequest",
      "position": { "x": 640, "y": 420 },
      "config": {
        "method": "GET",
        "url": "https://api.github.com/users/#{username}/repos?sort=stars&per_page=5",
        "headers": [{ "key": "Accept", "value": "application/vnd.github.v3+json", "enabled": true }],
        "body": "",
        "responseSchema": "z.array(z.object({\n  name: z.string(),\n  stargazers_count: z.number(),\n  language: z.string().nullable(),\n  description: z.string().nullable()\n}))"
      }
    },
    {
      "id": "foreach-repos",
      "kind": "forEachSequential",
      "position": { "x": 960, "y": 380 },
      "config": {}
    },
    {
      "id": "break-repo",
      "kind": "breakObject",
      "position": { "x": 1200, "y": 420 },
      "config": {}
    },
    {
      "id": "log-repo",
      "kind": "log",
      "position": { "x": 1200, "y": 260 },
      "config": { "label": "Top repo" }
    },
    {
      "id": "make-repo",
      "kind": "makeObject",
      "position": { "x": 1440, "y": 340 },
      "config": {
        "fields": [
          { "key": "name", "type": "string" },
          { "key": "stars", "type": "number" },
          { "key": "language", "type": "string" }
        ]
